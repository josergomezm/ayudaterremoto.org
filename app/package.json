{
  "name": "ayudaterremoto-app",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vue-tsc -b && vite build",
    "build:capacitor": "vue-tsc -b && vite build --mode capacitor",
    "preview": "vite preview",
    "lint": "eslint .",
    "cap:sync": "npm run build:capacitor && cap sync",
    "cap:ios": "npm run build:capacitor && cap sync ios && cap open ios",
    "cap:android": "npm run build:capacitor && cap sync android && cap open android",
    "cap:assets": "capacitor-assets generate"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.4.0",
    "@capacitor/device": "^7.0.0",
    "@capacitor/ios": "^7.4.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "firebase": "^11.0.0",
    "leaflet": "^1.9.4",
    "material-symbols": ">=0.25.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.24",
    "vue-i18n": "^11.1.0",
    "vue-router": "^4.6.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/leaflet": "^1.9.12",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.0",
    "vue-tsc": "^3.0.0"
  }
}
