rules_version = '2';

// All Firestore access goes through the `api` Cloud Function, which uses the
// Admin SDK (and bypasses these rules). Clients never touch Firestore directly,
// so we deny all direct client access. Lock this down before production.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
